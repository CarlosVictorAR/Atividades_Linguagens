<!DOCTYPE HTML>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8">

		<title>MMORPG - Game of Thrones</title>
		
		<!-- bootstrap - link cdn -->
		<link href="css/bootstrap.min.css" rel="stylesheet">
	
		<!-- incluindo css -->
		<link href="./css/style.css" rel="stylesheet">

	</head>

	<body class="body-index">

		<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
			<div class="container">
				<form class="d-flex form-entrar">
					<a href="/login"><button type="button" class="btn btn-success">Voltar</button></a>
				</form>
			</div>
			
		</nav>

	    <div class="container">

	    		<div class="alert alert-danger" id="erros" style="display: none" role="alert">
					<ul>
						<li></li>
					</ul>
				</div>
			<form id="form-cadastro" class="form-cadastro" method="post" action="/cadastrar">
			
				<div class="row">
					<div class="col-md-4">
						<div class="form-group">
							<label for="nome" class="form-label">Nome</label>
							<input type="nome" class="form-control" id="nome" name="nome" placeholder="Nome">
						</div>
					</div>
					
					<div class="col-md-4">
						<div class="form-group">
							<label for="usuario" class="form-label">Usuário</label>
							<input type="usuario" class="form-control" id="usuario" name="usuario" placeholder="Usuário">
						</div>
					</div>
					
					<div class="col-md-4">
						<div class="form-group">
							<label for="senha" class="form-label">Senha</label>
							<input type="password" class="form-control" id="senha" name="senha" placeholder="Password">
						</div>
					</div>
				</div>
				
				<div class="row g-3 mb-3">
        			<div class="col-md-2">
        				<img src="images/casa_arryn.jpg" class="img-fluid img-radio">
						<div class="text-center">
							<input type="radio" id="left-item" name="casa" value="arryn"> Casa Arryn
						</div>
        			</div>
					
					<div class="col-md-2">
        				<img src="images/casa_baratheon.jpg" class="img-fluid img-radio">
						<div class="text-center">
							<input type="radio" id="left-item" name="casa" value="baratheon"> Casa Baratheon
						</div>
        			</div>
					
					<div class="col-md-2">
        				<img src="images/casa_greyjoy.jpg" class="img-fluid img-radio">
						<div class="text-center">
							<input type="radio" id="left-item" name="casa" value="greyjoy"> Casa Greyjoy
						</div>
        			</div>
					
					<div class="col-md-2">
        				<img src="images/casa_lannister.jpg" class="img-fluid img-radio">
						<div class="text-center">
							<input type="radio" id="left-item" name="casa" value="lannister"> Casa Lannister
						</div>
        			</div>
					
					<div class="col-md-2">
        				<img src="images/casa_martell.jpg" class="img-fluid img-radio">
						<div class="text-center">
							<input type="radio" id="left-item" name="casa" value="martell"> Casa Martell
						</div>
        			</div>
					
					<div class="col-md-2">
        				<img src="images/casa_stark.jpg" class="img-fluid img-radio">
						<div class="text-center">
							<input type="radio" id="left-item" name="casa" value="stark"> Casa Stark
						</div>
        			</div>
        		</div>
				
				<div class="row g-3 mb-3">
				
					<div class="col-md-3"></div>
				
        			<div class="col-md-2">
        				<img src="images/casa_targaryen.jpg" class="img-fluid img-radio">
						<div class="text-center">
							<input type="radio" id="left-item" name="casa" value="targaryen"> Casa Targaryen
						</div>
        			</div>
					
					<div class="col-md-2">
        				<img src="images/casa_tully.jpg" class="img-fluid img-radio">
						<div class="text-center">
							<input type="radio" id="left-item" name="casa" value="tully"> Casa Tully
						</div>
        			</div>
					
					<div class="col-md-2">
        				<img src="images/casa_tyrell.jpg" class="img-fluid img-radio">
						<div class="text-center">
							<input type="radio" id="left-item" name="casa" value="tyrell"> Casa Tyrell
						</div>
        			</div>
					
					<div class="col-md-3"></div>
				</div>		
				

			</form>
			<div class="mt-2">
				<button type="submit" form="form-cadastro" class="btn btn-primary">Confirmar cadastro</button>
			</div>
	    </div>
		<script src="js/main.js"></script>
	</body>
</html>