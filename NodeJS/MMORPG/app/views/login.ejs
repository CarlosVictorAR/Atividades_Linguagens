<!DOCTYPE HTML>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8">

		<title>MMORPG - Game of Thrones</title>
		
		<!-- bootstrap - link cdn -->
		<link href="css/bootstrap.min.css" rel="stylesheet">
	
		<!-- incluindo css -->
		<link href="css/style.css" rel="stylesheet">

	</head>

	<body class="body-index">
		<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
			<div class="container">
				<div class="alert alert-danger" id="errosEntrar" style="display: none;" role="alert">
				</div>
				<form id="form-entrar" class="d-flex form-entrar" method="post" action="/login">
					<input type="text" name="usuario" id="usuario" placeholder="Usuário" class="form-control me-2" autocomplete="off" />
					<input type="password" name="senha" id="senha" placeholder="Senha" class="form-control me-2" />
					<button type="submit" form="form-entrar" class="btn btn-success me-2">Entrar</button>
					<a href="/cadastro"><button type="button" class="btn btn-info">Cadastro</button></a>
				</form>
			</div>
			
		</nav>

	    <div class="container">
	    	<div class="row">
	    		<div class="col-lg-2"></div>

	    		<div class="col-lg-8">
					<img src="images/game_of_thrones_logo.jpg" class="img-fluid" />
				</div>

	    		<div class="col-lg-2"></div>
		    	</div>
	    	</div>
	    </div>	
		<script src="js/main.js"></script>
	</body>
</html>